# Flow API credentials
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
# Obtain your refresh token from Flow app settings:
# Profile > API Tokens (or similar in your Flow instance)

export FLOW_REFRESH_TOKEN=your-refresh-token-here

# Your organisation alias as shown in the Flow URL
# e.g. https://app.flowengineering.com/org/<orgAlias>/...
export FLOW_ORG=your-org-alias-here

# Default project alias (can be overridden per command with --project)
export FLOW_PROJECT=your-project-alias-here
